{
  "name": "sks-hugo-web",
  "version": "0.0.4",
  "description": "Personal web site.",
  "repository": "https://github.com/SergeiZheleznov/SergeiZheleznov.github.io.git",
  "private": true,
  "scripts": {
    "lint": "tslint -c tslint.json 'src/js/**/*.ts'",
    "start": "run-p start:**",
    "start:hugo": "hugo -d ../dist -s site -vw",
    "start:webpack": "webpack-dev-server --config webpack.dev.js --hot",
    "preview": "run-p preview:**",
    "preview:hugo": "npm run start:hugo -- -D -F",
    "preview:webpack": "npm run start:webpack",
    "build": "npm run build:webpack && npm run build:hugo",
    "build:preview": "npm run build:webpack && npm run build:hugo:preview",
    "build:hugo": "hugo -d ../dist -s site -v --minify",
    "build:hugo:preview": "npm run build:hugo -- -D -F",
    "build:webpack": "cross-env NODE_ENV=production webpack --config webpack.prod.js"
  },
  "author": "Sergei Zheleznov",
  "license": "UNLICENSED",
  "devDependencies": {
    "@tailwindcss/ui": "^0.3.0",
    "alpinejs": "^2.3.5",
    "assets-webpack-plugin": "^3.9.12",
    "clean-webpack-plugin": "^3.0.0",
    "copy-webpack-plugin": "^6.0.0",
    "cross-env": "^5.2.0",
    "css-loader": "^3.4.1",
    "exports-loader": "^0.7.0",
    "fancy-log": "^1.3.2",
    "file-loader": "^4.1.0",
    "hugo-bin": "^0.52.2",
    "imports-loader": "^0.8.0",
    "mini-css-extract-plugin": "^0.9.0",
    "npm-run-all": "^4.1.5",
    "optimize-css-assets-webpack-plugin": "^5.0.3",
    "plugin-error": "^1.0.1",
    "postcss-import": "^12.0.1",
    "postcss-loader": "^3.0.0",
    "postcss-preset-env": "^6.7.0",
    "rimraf": "^3.0.0",
    "sass-loader": "^8.0.0",
    "style-loader": "^1.0.0",
    "ts-loader": "^7.0.4",
    "typescript": "^3.9.2",
    "url-loader": "^2.1.0",
    "webpack": "^4.43.0",
    "webpack-cli": "^3.3.11",
    "webpack-dev-server": "^3.11.0",
    "webpack-merge": "^4.2.2",
    "whatwg-fetch": "^3.0.0"
  },
  "resolutions": {
    "natives": "1.1.6"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.12.1",
    "@fortawesome/fontawesome-svg-core": "^1.2.27",
    "@fortawesome/free-brands-svg-icons": "^5.12.1",
    "@fortawesome/free-solid-svg-icons": "^5.12.1",
    "node-sass": "^4.14.1",
    "tailwindcss": "^1.4.6",
    "terser-webpack-plugin": "^3.0.1",
    "tslint": "^6.1.2"
  }
}
